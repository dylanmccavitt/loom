{
  "name": "loom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "bench": "node scripts/bench.mjs",
    "factory": "node scripts/factory-nucleus/factory.mjs",
    "doctor": "node scripts/doctor.mjs",
    "guard:worktree": "node scripts/worktree-guard.mjs",
    "choose-tracker": "node scripts/factory-nucleus/factory.mjs choose-tracker",
    "render-nucleus": "node scripts/render-nucleus.mjs",
    "render": "node scripts/render-skills-compat.mjs",
    "install-nucleus": "node scripts/render-nucleus.mjs --write",
    "smoke:live": "node --test tests/factory-nucleus-live-smoke.test.mjs",
    "runtime-adapter": "node scripts/runtime-adapter/server.mjs",
    "validate": "sh -c 'set -e; for f in scripts/validate-*.mjs; do node \"$f\"; done; node scripts/dry-run-harness-inventory.mjs; node scripts/dry-run-harness-safety-gate.mjs'",
    "lint": "npm run validate",
    "check": "npm run validate && npm test",
    "loop": "node scripts/loop.mjs"
  }
}
