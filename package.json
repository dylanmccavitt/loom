{
  "name": "loom",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "bench": "node scripts/bench.mjs",
    "guard:worktree": "node scripts/worktree-guard.mjs",
    "validate": "sh -c 'set -e; for f in scripts/validate-*.mjs; do node \"$f\"; done'",
    "lint": "npm run validate",
    "check": "npm run validate && npm test",
    "install:skills": "node scripts/install.mjs",
    "loop": "node scripts/loop.mjs"
  }
}
