{
  "name": "oh-my-pi-config",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "factory": "node scripts/factory-nucleus/factory.mjs",
    "render-nucleus": "node scripts/render-harness-nucleus.mjs",
    "install-nucleus": "node scripts/render-harness-nucleus.mjs --write",
    "runtime-adapter": "node scripts/runtime-adapter/server.mjs",
    "validate": "sh -c 'set -e; for f in scripts/validate-*.mjs; do node \"$f\"; done; node scripts/dry-run-harness-inventory.mjs; node scripts/dry-run-harness-safety-gate.mjs'",
    "check": "npm run validate && npm test"
  }
}
