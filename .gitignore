# Keep this repo declarative. Runtime state stays in ~/.omp.

# macOS
.DS_Store

# Node
node_modules/

# OMP runtime state
*.db
*.db-*
*.sqlite
*.sqlite-*
*-shm
*-wal
sessions/
terminal-sessions/
cache/
logs/
*.log
blobs/

# Secret/local overrides
*.local.yml
*.local.yaml
.factory/settings.local.json
*.secret.yml
*.secret.yaml

# Common credential files
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key

# App-managed skill runtime state written via the symlinked skills dir
# (e.g. Codex .system built-ins: skill-creator, plugin-creator, imagegen).
skills/.system/

# Generated model-judge scorecards (npm run bench -- --judge output).
retro/judge-scorecard-*

# Generated trigger-eval scorecards (npm run bench -- --triggers output).
retro/trigger-scorecard-*

# Generated eval dashboard (npm run dashboard output).
retro/eval-dashboard*
